# Database
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/marketingERP

# JWT
JWT_ACCESS_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# Redis (BullMQ job queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# Anthropic Claude API (AI insights & report generation)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (email notifications) — https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Marketing ERP <noreply@yourdomain.com>

# S3-compatible storage (AWS S3 or Cloudflare R2) — for task file attachments
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=marketing-erp-files
S3_REGION=us-east-1
# S3_ENDPOINT=  # set only for R2 / MinIO (e.g. https://<account>.r2.cloudflarestorage.com)

# Meta Ads OAuth (optional — required for Meta Ads sync)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://localhost:3001/api/meta/oauth/callback
