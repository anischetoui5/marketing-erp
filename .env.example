# ── docker-compose secrets (copy to .env and fill in) ────────────────────────

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

ANTHROPIC_API_KEY=sk-ant-...

# Resend (email notifications)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Marketing ERP <noreply@yourdomain.com>

# S3-compatible storage (task file attachments)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=marketing-erp-files
S3_REGION=us-east-1

# ── Optional: Meta Ads OAuth ─────────────────────────────────────────────────

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3001/api/meta/oauth/callback
